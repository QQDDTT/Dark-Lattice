<svg width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="latticeGradientIcon" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3B82F6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#8B5CF6;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Simplified Icosahedron Projection for Favicon -->
  <!-- Outer Hexagon -->
  <path d="M16 4 L26.4 10 L26.4 22 L16 28 L5.6 22 L5.6 10 Z" fill="none" stroke="url(#latticeGradientIcon)" stroke-width="2.5" stroke-linejoin="round" />
  
  <!-- Internal Main Connections -->
  <path d="M16 4 L16 28" fill="none" stroke="url(#latticeGradientIcon)" stroke-width="1.5" />
  <path d="M26.4 10 L5.6 22" fill="none" stroke="url(#latticeGradientIcon)" stroke-width="1.5" />
  <path d="M26.4 22 L5.6 10" fill="none" stroke="url(#latticeGradientIcon)" stroke-width="1.5" />
  
  <!-- Central Core Node -->
  <circle cx="16" cy="16" r="3" fill="url(#latticeGradientIcon)" />
</svg>
