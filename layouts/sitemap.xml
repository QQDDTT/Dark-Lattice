{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml"
  xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
  {{ range .Site.Pages }}
    {{ if and (ne .Kind "404") (not .Params.sitemap_exclude) (ne .Params.sitemap.disable true) }}
    <url>
      <loc>{{ .Permalink }}</loc>
      {{ if not .Lastmod.IsZero }}
        <lastmod>{{ safeHTML ( .Lastmod.Format "2006-01-02T15:04:05-07:00" ) }}</lastmod>
      {{ end }}
      {{ with .Sitemap.ChangeFreq }}
        <changefreq>{{ . }}</changefreq>
      {{ else }}
        <changefreq>weekly</changefreq>
      {{ end }}
      {{ if .IsHome }}
        <priority>1.0</priority>
      {{ else if or (eq .Section "posts") (eq .Section "research") }}
        <priority>0.8</priority>
      {{ else if .Sitemap.Priority }}
        <priority>{{ .Sitemap.Priority }}</priority>
      {{ else }}
        <priority>0.5</priority>
      {{ end }}
      {{ if .IsTranslated }}
        {{ range .AllTranslations }}
          <xhtml:link
            rel="alternate"
            hreflang="{{ .Language.LanguageCode }}"
            href="{{ .Permalink }}"
            />
        {{ end }}
      {{ end }}
      {{/* 图片 Sitemap 支持 */}}
      {{ $pageTitle := .Title }}
      {{ if .Params.background }}
        <image:image>
          <image:loc>{{ .Params.background | absURL }}</image:loc>
          <image:title>{{ $pageTitle }}</image:title>
        </image:image>
      {{ end }}
      {{ range .Resources.ByType "image" }}
        <image:image>
          <image:loc>{{ .Permalink }}</image:loc>
          <image:title>{{ $pageTitle }}</image:title>
        </image:image>
      {{ end }}
    </url>
    {{ end }}
  {{ end }}
</urlset>
