{
  "version": 2,
  "framework": "hugo",
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "hugo --minify --gc",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    }
  ]
}

