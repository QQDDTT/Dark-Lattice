{
  "version": 2,
  "framework": "hugo",
  "cleanUrls": true,
  "trailingSlash": true,
  "buildCommand": "hugo --minify --gc",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)sitemap\\.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    }
  ],
  "build": {
    "env": {
      "HUGO_VERSION": "0.121.2"
    }
  }
}